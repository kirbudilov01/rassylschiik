# App
APP_NAME=AI Outreach Platform
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8080

# Database
DATABASE_URL=sqlite:///./data/app.db

# Telegram user accounts (future integration via Telethon)
# Comma-separated account aliases, example: sales_ru_1,sales_ru_2
TG_ACCOUNT_ALIASES=sales_ru_1

# AI provider config (future integration)
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=

# Safety and outreach policy
OUTREACH_HUMAN_REVIEW_REQUIRED=true
MAX_OUTREACH_PER_ACCOUNT_PER_HOUR=3
MAX_OUTREACH_PER_ACCOUNT_PER_DAY=5
MAX_NEW_DIALOGS_PER_ACCOUNT_PER_DAY=20
DAILY_SEND_MIN_TARGET=3
DAILY_SEND_MAX_TARGET=5

# Lead scoring thresholds
MIN_LEAD_SCORE=0.65

# Worker
WORKER_POLL_SECONDS=8
WORKER_BATCH_SIZE=20
