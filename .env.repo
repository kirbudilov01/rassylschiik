# Repo-level variables (intentionally stored in repository for convenience)
# WARNING: do not use real production secrets here.

APP_NAME=AI Outreach Platform
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8080

DATABASE_URL=sqlite:///./data/app.db

# Telegram
TG_ACCOUNT_ALIASES=sales_ru_1,sales_ru_2
TG_API_ID=
TG_API_HASH=

# Optional future per-account sessions
TG_SESSION_SALES_RU_1=
TG_SESSION_SALES_RU_2=

# AI
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=REPLACE_WITH_YOUR_KEY

# Outreach policy
OUTREACH_HUMAN_REVIEW_REQUIRED=true
MAX_OUTREACH_PER_ACCOUNT_PER_HOUR=3
MAX_OUTREACH_PER_ACCOUNT_PER_DAY=5
MAX_NEW_DIALOGS_PER_ACCOUNT_PER_DAY=20
MIN_LEAD_SCORE=0.65
DAILY_SEND_MIN_TARGET=3
DAILY_SEND_MAX_TARGET=5

# Worker
WORKER_POLL_SECONDS=8
WORKER_BATCH_SIZE=20

# Keyword gate source file
KEYWORD_PACK_FILE=config/keyword_pack_youtube_ru.json
